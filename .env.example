# ─── Database ───────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET="your-secret-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
